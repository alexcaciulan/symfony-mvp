{# Individual defendant form fields #}
<div data-controller="conditional-fields company-lookup"
     data-conditional-fields-show-value="pj"
     data-company-lookup-url-value="{{ path('case_company_lookup', {cui: '__CUI__'}) }}">
    {# Type (PF/PJ) #}
    <div class="mb-4">
        <span class="block text-sm font-medium text-gray-700 mb-2">{{ 'wizard.step3.type'|trans }}</span>
        <div class="flex gap-4">
            {% for child in defendant.type %}
                <label class="flex items-center gap-2 cursor-pointer">
                    {{ form_widget(child, { attr: {
                        class: 'text-primary-light focus:ring-primary-light',
                        'data-conditional-fields-target': loop.first ? 'source' : '',
                        'data-action': 'change->conditional-fields#toggle',
                    }}) }}
                    <span class="text-sm text-gray-700">{{ child.vars.label|trans }}</span>
                </label>
            {% endfor %}
        </div>
    </div>

    {# Name #}
    <div class="mb-4">
        {{ form_label(defendant.name, null, { label_attr: { class: 'block text-sm font-medium text-gray-700 mb-1' }}) }}
        {{ form_widget(defendant.name, { attr: {
            class: 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-light',
            'data-company-lookup-target': 'nameField',
        }}) }}
        {{ form_errors(defendant.name) }}
    </div>

    {# PF: CNP #}
    <div data-conditional-fields-target="inverse" class="mb-4">
        {{ form_label(defendant.cnp, null, { label_attr: { class: 'block text-sm font-medium text-gray-700 mb-1' }}) }}
        {{ form_widget(defendant.cnp, { attr: { class: 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-light' }}) }}
    </div>

    {# PJ: CUI + Company name + Lookup button #}
    <div data-conditional-fields-target="conditional" class="space-y-4 mb-4">
        <div>
            {{ form_label(defendant.cui, null, { label_attr: { class: 'block text-sm font-medium text-gray-700 mb-1' }}) }}
            <div class="flex gap-2">
                {{ form_widget(defendant.cui, { attr: {
                    class: 'flex-1 px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-light',
                    'data-company-lookup-target': 'cuiInput',
                }}) }}
                <button type="button"
                        class="px-3 py-2 bg-primary-light text-white rounded-lg hover:bg-primary-dark text-sm whitespace-nowrap transition-colors"
                        data-company-lookup-target="lookupButton"
                        data-action="company-lookup#lookup">
                    {{ 'wizard.step3.lookup_button'|trans }}
                </button>
            </div>
            <p data-company-lookup-target="statusMessage" class="text-sm mt-1 hidden"></p>
        </div>
        <div>
            {{ form_label(defendant.companyName, null, { label_attr: { class: 'block text-sm font-medium text-gray-700 mb-1' }}) }}
            {{ form_widget(defendant.companyName, { attr: {
                class: 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-light',
                'data-company-lookup-target': 'companyNameField',
            }}) }}
        </div>
    </div>
</div>

